# ============================================================
# TicketPilot Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ---- Supabase (public — safe to expose) ----------------------
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Project Settings → API → Project API Keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Backend API URL -----------------------------------------
# Local dev: point at your locally running FastAPI server.
# NOTE: the variable name is NEXT_PUBLIC_API_URL (not API_BASE).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production example:
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# ---- Optional flags ------------------------------------------
# Set to "true" during local dev to relax certain Supabase checks.
NEXT_PUBLIC_LOCAL_DEV=true
