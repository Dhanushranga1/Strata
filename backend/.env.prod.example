# ============================================================
# TicketPilot Backend — PRODUCTION environment
# Set these in the Render dashboard (NOT in a .env file).
# ============================================================

# ---- Supabase (use a PROD project) --------------------------
SUPABASE_URL=https://your-prod-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---- Database -----------------------------------------------
# Prod Supabase transaction-pooler URL (port 6543).
DATABASE_URL=postgresql://postgres.[prod-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ---- CORS ---------------------------------------------------
# Set to your actual frontend domain, no trailing slash.
WEB_ORIGIN=https://your-app.vercel.app

# ---- Google AI / Groq ---------------------------------------
GOOGLE_API_KEY=
GROQ_API_KEY=
JINA_API_KEY=

# ---- Runtime ------------------------------------------------
ENVIRONMENT=production
LOG_LEVEL=INFO
API_VERSION=0.1.0

# ---- FAISS --------------------------------------------------
VECTOR_INDEX_DIR=./data/faiss
VECTOR_MAP_DIR=./data/maps

# ---- Document chunking --------------------------------------
CHUNK_SIZE_CHARS=2400
CHUNK_OVERLAP_CHARS=400

# ---- AI generation ------------------------------------------
GENAI_MODEL=gemini-1.5-flash
GENAI_TEMPERATURE=0.2
GENAI_MAX_OUTPUT_TOKENS=1024

# ---- RAG ----------------------------------------------------
RAG_TOP_K=6
RAG_MIN_SCORE=0.25
RAG_MAX_CONTEXT_CHARS=12000

# ---- Confidence & escalation --------------------------------
CONFIDENCE_MIN_CHUNKS=2
CONFIDENCE_THRESHOLD=0.55

# ---- Rate limiting ------------------------------------------
CHAT_COOLDOWN_SECONDS=8
