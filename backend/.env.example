# ============================================================
# TicketPilot Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.
# ============================================================

# ---- Supabase ---------------------------------------------------
# Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Project Settings → API → Project API Keys → anon / public
SUPABASE_ANON_KEY=

# Project Settings → API → Project API Keys → service_role  (keep secret!)
# Required for invite emails. If absent, invite links are returned in the
# API response body so the admin can copy-paste them manually (local dev).
SUPABASE_SERVICE_ROLE_KEY=

# Project Settings → API → JWT Settings → JWT Secret
# This is a raw string (NOT the service_role JWT token itself).
# Find it at: supabase.com → your project → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# ---- Database ---------------------------------------------------
# Supabase transaction-pooler URL (IPv4-safe, port 6543).
# Dashboard: Project Settings → Database → Connection string → URI
# Use the "Transaction mode" pooler for FastAPI (not the session-mode one).
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ---- CORS / origin ----------------------------------------------
# The URL where your frontend runs. In production, set to your Vercel URL.
WEB_ORIGIN=http://localhost:3000

# ---- Google AI --------------------------------------------------
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ---- Runtime / logging -----------------------------------------
ENVIRONMENT=development        # development | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
API_VERSION=0.1.0

# ---- FAISS vector store ----------------------------------------
# Local paths — gitignored. On ephemeral deploys (Render/Railway) these
# are wiped on every deploy; re-upload KB documents after each deploy.
VECTOR_INDEX_DIR=./data/faiss
VECTOR_MAP_DIR=./data/maps

# ---- Document chunking -----------------------------------------
CHUNK_SIZE_CHARS=2400
CHUNK_OVERLAP_CHARS=400

# ---- AI generation (Gemini) ------------------------------------
GENAI_MODEL=gemini-1.5-flash
GENAI_TEMPERATURE=0.2
GENAI_MAX_OUTPUT_TOKENS=1024

# ---- RAG retrieval tuning --------------------------------------
RAG_TOP_K=6
RAG_MIN_SCORE=0.25
RAG_MAX_CONTEXT_CHARS=12000

# ---- Confidence & escalation thresholds ------------------------
CONFIDENCE_MIN_CHUNKS=2
CONFIDENCE_THRESHOLD=0.55

# ---- Simple per-ticket rate limiting ---------------------------
CHAT_COOLDOWN_SECONDS=8
