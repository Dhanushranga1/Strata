# CORS allowlist (frontend URL)
WEB_ORIGIN=http://localhost:3000

# Supabase JWT secret (Project Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=

# Embeddings provider
EMBEDDINGS_PROVIDER=google
GOOGLE_API_KEY=

# FAISS paths
VECTOR_INDEX_DIR=./data/faiss
VECTOR_INDEX_FILENAME=kb.index
VECTOR_MAP_DIR=./data/maps
VECTOR_MAP_FILENAME=kb_map.json

# Chunking
CHUNK_SIZE_CHARS=2400
CHUNK_OVERLAP_CHARS=400

# Optional future use (Phase 2+)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
API_VERSION=0.1.0

# Phase 4: AI Chat with RAG
# LLM generation
GENAI_MODEL=gemini-1.5-pro
GENAI_TEMPERATURE=0.2
GENAI_MAX_OUTPUT_TOKENS=1024

# RAG controls
RAG_TOP_K=6
RAG_MIN_SCORE=0.25
RAG_MAX_CONTEXT_CHARS=12000

# Confidence & escalation
CONFIDENCE_MIN_CHUNKS=2
CONFIDENCE_THRESHOLD=0.55

# Simple rate limiting (per ticket)
CHAT_COOLDOWN_SECONDS=8