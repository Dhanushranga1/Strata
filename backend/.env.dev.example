# ============================================================
# TicketPilot Backend — DEV environment
# Copy this file to .env for local development:
#   cp backend/.env.dev.example backend/.env
# ============================================================

# ---- Supabase (use a DEV project — NOT production) -----------
SUPABASE_URL=https://your-dev-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---- Database -----------------------------------------------
# Dev Supabase transaction-pooler URL (port 6543).
DATABASE_URL=postgresql://postgres.[dev-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ---- CORS ---------------------------------------------------
WEB_ORIGIN=http://localhost:3000

# ---- AI Generation (BYOK — auto-detect provider from model name) ----
# gemini-*  → Google Gemini (uses GOOGLE_API_KEY)
# gpt-*     → OpenAI (uses GENAI_API_KEY)
# claude-*  → Anthropic (uses GENAI_API_KEY)
# else      → OpenAI-compatible: Groq, Together, etc. (GENAI_API_KEY + GENAI_API_BASE)
GENAI_MODEL=gemini-2.0-flash
GENAI_API_KEY=                                                # shared key for OpenAI-compatible providers
GOOGLE_API_KEY=                                               # used when GENAI_MODEL starts with gemini-
GENAI_API_BASE=                                               # e.g. https://api.groq.com/openai/v1

# ---- Embeddings (BYOK — auto-detect provider from model name) -------
# gemini-embedding-* → Google, text-embedding-* → OpenAI, else → Jina
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_API_KEY=                                            # if unset, falls back to GOOGLE_API_KEY
EMBEDDING_DIM=                                                # auto-detected, override if needed

# ---- Runtime ------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG
API_VERSION=0.1.0

# ---- FAISS --------------------------------------------------
VECTOR_INDEX_DIR=./data/faiss
VECTOR_MAP_DIR=./data/maps

# ---- Document chunking --------------------------------------
CHUNK_SIZE_CHARS=2400
CHUNK_OVERLAP_CHARS=400

# ---- AI generation ------------------------------------------
GENAI_MODEL=gemini-1.5-flash
GENAI_TEMPERATURE=0.2
GENAI_MAX_OUTPUT_TOKENS=1024

# ---- RAG ----------------------------------------------------
RAG_TOP_K=6
RAG_MIN_SCORE=0.25
RAG_MAX_CONTEXT_CHARS=12000

# ---- Confidence & escalation --------------------------------
CONFIDENCE_MIN_CHUNKS=2
CONFIDENCE_THRESHOLD=0.55

# ---- Rate limiting ------------------------------------------
CHAT_COOLDOWN_SECONDS=8
